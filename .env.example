# ==========================================
# p3pp4 — AI Physics Solver
# ==========================================
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env real para o GitHub!
# ==========================================

# Banco de dados (SQLite local para desenvolvimento)
DATABASE_URL="file:./db/custom.db"

# Para Supabase (produção), troque para:
# DATABASE_URL="postgresql://postgres.[SEU_PROJETO]:[SUA_SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres"

# Z.AI API Key (não é necessária no .env — o z-ai CLI já está configurado no servidor)
# Se for usar em produção, configure a variável de ambiente:
# ZAI_API_KEY="sua_chave_aqui"
