generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SolverSession {
  id            String   @id @default(cuid())
  url           String
  userName      String   @default("Physics Bot")
  status        String   @default("pending")  // pending, running, solved, error
  simulatorType String?
  enunciado     String?
  variaveis     String?  // JSON
  calculos      String?
  respostas     String?  // JSON
  respostasCorretas String? // JSON
  resultado     String?
  metodo        String?
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Memória de adaptação — salva padrões de resolução para reuso
model SolverPattern {
  id              String   @id @default(cuid())
  simulatorType   String   // ex: "CarStoppingProblem", "UniversalGravityProblem"
  urlPattern      String   // parte da URL que identifica o tipo
  variaveisNecessarias String // JSON: lista de variáveis JS necessárias ["StartingSpeed","MassOfCar"]
  formulaResolucao String  // JSON: fórmulas e lógica de cálculo
  camposResposta  String   // JSON: labels dos campos ["Time (s):", "Displacement (m):"]
  metodo          String   // "calculo_direto" ou "ia"
  vezesUsado      Int      @default(1)
  vezesCorreto    Int      @default(0)
  ultimaUrl       String?  // última URL que usou este padrão
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([simulatorType])
}
